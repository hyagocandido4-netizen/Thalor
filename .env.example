# IQ Option credentials (REQUIRED)
# Copy this file to `.env` and fill with your credentials.
# IMPORTANT: `.env` must NEVER be committed.

IQ_EMAIL=your@email.com
IQ_PASSWORD=your_password

# PRACTICE (recommended) or REAL
IQ_BALANCE_MODE=PRACTICE

# Optional / advanced toggles (safe defaults)

# Disable API-based market-open checks by default.
# Some iqoptionapi versions may spawn background threads that can crash noisily
# (ex.: KeyError: 'underlying' from digital open paths). Thalor can infer market
# status from candle freshness instead.
IQ_MARKET_OPEN_USE_API=0
