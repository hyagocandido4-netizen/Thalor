# Example environment file (do NOT commit your real .env with credentials)
# Copy to .env and fill your real values locally.

# --- IQ Option credentials ---
IQ_EMAIL="you@example.com"
IQ_PASSWORD="YOUR_PASSWORD"

# --- Optional: IQClient pacing / throttling (stability only) ---
# When running multi-asset pipelines in parallel, this can reduce bursty requests.
IQ_THROTTLE_MIN_INTERVAL_S=0.0
IQ_THROTTLE_JITTER_S=0.0
# IQ_THROTTLE_STATE_FILE=runs/iq_throttle_state.json

# --- Optional: existing retry knobs (advanced) ---
# IQ_CONNECT_RETRIES=3
# IQ_CONNECT_SLEEP_S=2.0
# IQ_CALL_RETRIES=3
# IQ_CALL_SLEEP_S=1.0

# Execução (Config2 / Pydantic settings override)
# Use em Docker/CI para ligar/desligar execução e forçar modo "paper".
# (hotfix5: THALOR__EXECUTION__ENABLED é respeitado pelo runner)
THALOR__EXECUTION__ENABLED=0
THALOR__EXECUTION__MODE=paper

