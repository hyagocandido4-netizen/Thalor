# Example environment file (do NOT commit your real .env with credentials)
# Copy to .env and prefer pointing to external secret files instead of putting
# raw broker credentials directly here.

# --- Preferred credential flow (Package M6) ---
# Option A: one bundle file (YAML / JSON / KEY=VALUE)
THALOR_SECRETS_FILE="secrets/broker.yaml"

# Option B: separate files (override the bundle if both are present)
# THALOR_BROKER_EMAIL_FILE="secrets/broker_email.txt"
# THALOR_BROKER_PASSWORD_FILE="secrets/broker_password.txt"

# --- Compatibility fallback (discouraged for live) ---
# IQ_EMAIL="you@example.com"
# IQ_PASSWORD="YOUR_PASSWORD"
IQ_BALANCE_MODE="PRACTICE"

# --- Security posture / deployment profile ---
THALOR__SECURITY__DEPLOYMENT_PROFILE="local"
THALOR__SECURITY__LIVE_REQUIRE_EXTERNAL_CREDENTIALS="0"
THALOR__SECURITY__GUARD__MIN_SUBMIT_SPACING_SEC="10"
THALOR__SECURITY__GUARD__MAX_SUBMIT_PER_MINUTE="4"
# THALOR__SECURITY__GUARD__TIME_FILTER_ENABLE="1"
# THALOR__SECURITY__GUARD__ALLOWED_START_LOCAL="09:00"
# THALOR__SECURITY__GUARD__ALLOWED_END_LOCAL="17:00"

# --- IQ client pacing / throttling (stability only) ---
# Prefer the typed config keys broker.api_throttle_* when possible.
IQ_THROTTLE_MIN_INTERVAL_S=0.0
IQ_THROTTLE_JITTER_S=0.0
# IQ_THROTTLE_STATE_FILE=runs/iq_throttle_state.json

# --- Optional: existing retry knobs (advanced) ---
# IQ_CONNECT_RETRIES=3
# IQ_CONNECT_SLEEP_S=2.0
# IQ_CALL_RETRIES=3
# IQ_CALL_SLEEP_S=1.0

# Execution / trading behavior
# Overrides comportamentais vindos do `.env` local ficam BLOQUEADOS por padrão.
# Para Docker/CI, prefira exportar no processo (ou habilite explicitamente com
# `THALOR_DOTENV_ALLOW_BEHAVIOR=1` no shell antes de subir o runtime).
# THALOR__EXECUTION__ENABLED=0
# THALOR__EXECUTION__MODE=paper

# --- Telegram / Alerting (M7) ---
# THALOR_TELEGRAM_BOT_TOKEN_FILE="secrets/telegram_bot_token.txt"
# THALOR_TELEGRAM_CHAT_ID_FILE="secrets/telegram_chat_id.txt"
# THALOR_TELEGRAM_BOT_TOKEN="123456:ABCDEF"
# THALOR_TELEGRAM_CHAT_ID="123456789"
THALOR__NOTIFICATIONS__TELEGRAM__ENABLED=0
THALOR__NOTIFICATIONS__TELEGRAM__SEND_ENABLED=0

# Package 5 — production prep
THALOR__PRODUCTION__ENABLED=0
THALOR__PRODUCTION__PROFILE=local
THALOR__PRODUCTION__BACKUP__ENABLED=1
THALOR__PRODUCTION__HEALTHCHECK__ENABLED=1
