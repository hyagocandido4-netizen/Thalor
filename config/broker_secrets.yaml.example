# Copy this file to config/broker_secrets.yaml (ignored by git)
# and fill the real broker credentials locally.

broker:
  email: you@example.com
  password: YOUR_PASSWORD_HERE
  balance_mode: PRACTICE


telegram:
  bot_token: TELEGRAM_BOT_TOKEN_HERE
  chat_id: TELEGRAM_CHAT_ID_HERE


# Opcional: overrides secretos para transporte e request-metrics
network:
  transport:
    # endpoint: socks5h://user:pass@proxy.example.internal:7000?name=primary
    # endpoint_file: secrets/transport_endpoint
    no_proxy: localhost,127.0.0.1

observability:
  request_metrics:
    enabled: true
    timezone: America/Sao_Paulo
    structured_log_path: runs/logs/request_metrics.jsonl
    emit_request_events: true
    emit_summary_every_requests: 25
