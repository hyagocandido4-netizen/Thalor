# ================================
# Python
# ================================
__pycache__/
*.py[cod]
*$py.class

# Virtualenvs
.venv/
venv/
ENV/

# Build / packaging
build/
dist/
htmlcov/
*.egg-info/
*.whl

# Test / type / lint caches
.pytest_cache/
.mypy_cache/
.ruff_cache/
.hypothesis/
.cache/
.coverage

# ================================
# OS / editors
# ================================
.DS_Store
Thumbs.db
.vscode/
.idea/
*.swp
*.tmp

# ================================
# Secrets / local config
# ================================
.env
.env.*
!.env.example

# Local config variants (do not version)
configs/variants/
config_*.yml
config_*.yaml

# External secrets / local secret bundles
secrets/
config/*secret.yaml
config/*secret.yml
config/*secrets.yaml
config/*secrets.yml

# ================================
# Runtime artifacts (generated)
# ================================
